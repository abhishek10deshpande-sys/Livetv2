# ─────────────────────────────────────────────────────
#  Fantastic Live TV — Environment Variables
#  Copy to .env and fill in values before running locally
# ─────────────────────────────────────────────────────

# Port the server listens on
PORT=7860

# Host (0.0.0.0 for Docker/Render, 127.0.0.1 for local-only)
HOST=0.0.0.0

# Public base URL of your deployment — used in the landing page and install link
# Examples:
#   http://localhost:7860              (local)
#   https://fantastic-live-tv.onrender.com  (Render)
BASE_URL=http://localhost:7860

# Log level: error | warn | info | debug
LOG_LEVEL=info

# Write logs to files in addition to stdout (true | false)
LOG_TO_FILE=false

# Admin token for the POST /admin/flush-cache endpoint
# Leave empty to disable auth (not recommended in production)
ADMIN_TOKEN=

# Node environment
NODE_ENV=development
